# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (auto-populated by `pnpm bootstrap` from `supabase status`)
# Manual fallback: run `supabase status` and copy values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (auto-populated by bootstrap; uses Supabase local Postgres)
DATABASE_URL=

# Sentry (leave empty for local dev to avoid noise in your Sentry dashboard)
# Get from https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# PostHog (leave empty for local dev to avoid polluting production analytics)
# Get from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# OAuth providers (consumed by Supabase Auth via `supabase/config.toml`).
#
# Google — register at https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:54321/auth/v1/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
#
# Facebook — register at https://developers.facebook.com/apps/
#   Valid OAuth Redirect URI: http://localhost:54321/auth/v1/callback
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# Rate-limit backing store (Vercel Marketplace Redis, branded "Vercel KV").
# Provision via the Vercel dashboard → Storage → Marketplace; the platform
# auto-injects these vars. When empty, rate-limit falls back to an
# in-memory counter — fine for dev, NOT safe for multi-instance prod.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Logging
LOG_LEVEL=info
